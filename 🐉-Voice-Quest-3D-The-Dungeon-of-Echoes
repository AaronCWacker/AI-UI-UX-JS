<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>🐉 Voice Quest 3D: The Dungeon of Echoes</title>
<style>
  :root {
    --parchment: #f4e4bc;
    --ink: #2a1810;
    --blood: #8b1a1a;
    --gold: #c9a227;
    --shadow: #1a0f0a;
    --magic: #5b3a8e;
    --green: #3a6b3a;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Georgia', serif;
    background: radial-gradient(ellipse at top, #2a1a1a 0%, #0a0505 100%);
    color: var(--parchment);
    min-height: 100vh;
    padding: 10px;
    overflow-x: hidden;
  }
  .container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 12px;
  }
  @media (max-width: 900px) { .container { grid-template-columns: 1fr; } }

  h1 {
    font-size: 1.9em;
    text-align: center;
    color: var(--gold);
    text-shadow: 2px 2px 8px var(--blood), 0 0 20px rgba(201,162,39,0.4);
    letter-spacing: 2px;
    grid-column: 1 / -1;
  }
  .subtitle {
    text-align: center;
    font-style: italic;
    color: #b8a878;
    margin-bottom: 8px;
    grid-column: 1 / -1;
    font-size: 0.9em;
  }

  .panel {
    background: linear-gradient(135deg, #f4e4bc 0%, #e8d4a0 100%);
    color: var(--ink);
    border: 3px solid var(--gold);
    border-radius: 10px;
    padding: 14px;
    box-shadow: 0 0 30px rgba(0,0,0,0.6), inset 0 0 20px rgba(139,26,26,0.1);
  }

  #arenaWrap {
    position: relative;
    background: linear-gradient(180deg, #1a0a0a 0%, #050202 100%);
    border: 3px solid var(--gold);
    border-radius: 10px;
    overflow: hidden;
    height: 380px;
    box-shadow: 0 0 30px rgba(0,0,0,0.8), inset 0 0 40px rgba(139,26,26,0.3);
  }
  #arena3d {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  #arenaOverlay {
    position: absolute;
    top: 8px; left: 8px;
    color: var(--gold);
    font-family: monospace;
    font-size: 0.85em;
    background: rgba(0,0,0,0.6);
    padding: 6px 10px;
    border-radius: 4px;
    border: 1px solid var(--gold);
    pointer-events: none;
    z-index: 10;
  }
  #arenaState {
    position: absolute;
    top: 8px; right: 8px;
    color: var(--parchment);
    font-family: monospace;
    font-size: 0.85em;
    background: rgba(0,0,0,0.7);
    padding: 6px 10px;
    border-radius: 4px;
    border: 1px solid var(--blood);
    pointer-events: none;
    z-index: 10;
  }
  #floatingDamage {
    position: absolute;
    pointer-events: none;
    inset: 0;
    z-index: 5;
  }
  .dmg-popup {
    position: absolute;
    color: #ff4444;
    font-size: 1.5em;
    font-weight: bold;
    text-shadow: 2px 2px 4px black;
    animation: float-up 1.2s ease-out forwards;
    pointer-events: none;
  }
  .dmg-popup.heal { color: #4aff4a; }
  .dmg-popup.crit { color: #ffd700; font-size: 2em; }
  @keyframes float-up {
    0%   { transform: translateY(0); opacity: 1; }
    100% { transform: translateY(-60px); opacity: 0; }
  }

  .quick-actions {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    margin-top: 8px;
  }
  .quick-btn {
    background: linear-gradient(180deg, var(--blood) 0%, #5a0f0f 100%);
    color: var(--parchment);
    border: 2px solid var(--gold);
    padding: 10px 6px;
    font-family: 'Georgia', serif;
    font-weight: bold;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.15s;
    font-size: 0.95em;
  }
  .quick-btn:hover:not(:disabled) {
    transform: translateY(-2px) scale(1.03);
    box-shadow: 0 4px 12px rgba(201,162,39,0.6);
    background: linear-gradient(180deg, var(--gold) 0%, #8a6f1a 100%);
    color: var(--ink);
  }
  .quick-btn:disabled { opacity: 0.3; cursor: not-allowed; }
  .quick-btn .icon { font-size: 1.4em; display: block; }
  .quick-btn .name { font-size: 0.8em; }
  .quick-btn .cd { display: block; font-size: 0.7em; color: var(--gold); }

  #narrative {
    min-height: 200px;
    max-height: 35vh;
    overflow-y: auto;
    font-size: 1em;
    line-height: 1.55;
    padding: 14px;
  }
  #narrative .turn {
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 1px dashed rgba(42,24,16,0.3);
  }
  #narrative .turn:last-child { border-bottom: none; }
  #narrative .dm::first-letter {
    font-size: 1.8em; font-weight: bold; color: var(--blood);
    float: left; line-height: 0.9; margin-right: 4px;
  }
  #narrative .you {
    color: var(--magic); font-style: italic; font-weight: bold; margin-top: 6px;
  }
  #narrative .roll {
    display: inline-block; background: var(--shadow); color: var(--gold);
    padding: 2px 10px; border-radius: 4px; font-family: monospace; font-weight: bold;
  }
  #narrative .crit { color: var(--green); font-weight: bold; }
  #narrative .fail { color: var(--blood); font-weight: bold; }

  .controls {
    display: flex; gap: 6px; margin-top: 8px; flex-wrap: wrap;
  }
  .controls button {
    background: linear-gradient(180deg, var(--magic) 0%, #2a1a4a 100%);
    color: var(--parchment);
    border: 2px solid var(--gold);
    padding: 10px 14px;
    font-family: 'Georgia', serif;
    font-weight: bold;
    border-radius: 6px;
    cursor: pointer;
    flex: 1;
    min-width: 100px;
  }
  .controls button:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(201,162,39,0.5);
  }
  .controls button.mic-on {
    background: linear-gradient(180deg, var(--green) 0%, #1a4a1a 100%);
    animation: pulse 1.2s infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(58,107,58,0.7); }
    50% { box-shadow: 0 0 0 12px rgba(58,107,58,0); }
  }
  #textInput {
    width: 100%; padding: 8px; margin-top: 6px;
    border: 2px solid var(--gold); border-radius: 6px;
    font-family: 'Georgia', serif; font-size: 0.95em;
    background: rgba(255,255,255,0.7); color: var(--ink);
  }

  .sidebar { display: flex; flex-direction: column; gap: 10px; }
  .stat-block { padding: 12px; }
  .stat-block h3 {
    color: var(--blood);
    border-bottom: 2px solid var(--gold);
    padding-bottom: 4px;
    margin-bottom: 6px;
    font-variant: small-caps;
    letter-spacing: 1px;
    font-size: 1em;
  }
  .stat-row {
    display: flex; justify-content: space-between;
    margin: 3px 0; font-size: 0.9em;
  }
  .stat-row .value { color: var(--blood); font-family: monospace; }
  .hp-bar {
    height: 20px; background: #3a1a1a; border: 2px solid var(--ink);
    border-radius: 4px; overflow: hidden; position: relative; margin: 4px 0;
  }
  .hp-fill { height: 100%; background: linear-gradient(90deg, var(--green), #6abf69); transition: width 0.4s; }
  .hp-bar.low .hp-fill { background: linear-gradient(90deg, var(--blood), #d9534f); }
  .hp-text {
    position: absolute; inset: 0; text-align: center;
    line-height: 16px; color: white; font-weight: bold;
    text-shadow: 1px 1px 2px black; font-size: 0.8em;
  }
  .inventory-item {
    display: inline-block; background: var(--magic); color: var(--parchment);
    padding: 2px 8px; border-radius: 12px; margin: 2px; font-size: 0.8em;
  }

  #status {
    text-align: center; padding: 4px;
    font-style: italic; color: #b8a878;
    min-height: 22px; grid-column: 1 / -1; font-size: 0.9em;
  }

  .char-select {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 8px; margin: 10px 0;
  }
  .char-card {
    cursor: pointer; padding: 10px;
    border: 2px solid var(--ink); border-radius: 6px;
    text-align: center; background: rgba(255,255,255,0.4);
    transition: all 0.2s;
    user-select: none;
  }
  .char-card:hover { background: var(--gold); transform: scale(1.05); }
  .char-card:active { transform: scale(0.97); }
  .char-card .icon { font-size: 2.2em; pointer-events: none; }
  .char-card .name { font-weight: bold; color: var(--blood); font-size: 0.85em; pointer-events: none; }
  .char-card .desc { font-size: 0.75em; margin-top: 2px; pointer-events: none; }

  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
  ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 4px; }
  .mute-row {
    display: flex; align-items: center; gap: 6px;
    font-size: 0.8em; color: var(--ink); margin-top: 6px;
  }
</style>
</head>
<body>

<div class="container">
  <h1>🐉 Voice Quest 3D: The Dungeon of Echoes 🗡️</h1>
  <div class="subtitle">Voice-driven story • Quick-click 3D combat • d20 rolls drive auto-fighting</div>

  <div>
    <div id="arenaWrap">
      <canvas id="arena3d"></canvas>
      <div id="arenaOverlay">⚔️ TACTICAL ARENA · Drag to rotate · Scroll to zoom</div>
      <div id="arenaState">— STANDBY —</div>
      <div id="floatingDamage"></div>
    </div>

    <div class="quick-actions" id="quickActions">
      <button class="quick-btn" data-act="strike"   disabled><span class="icon">⚔️</span><span class="name">Strike</span><span class="cd">d20+STR</span></button>
      <button class="quick-btn" data-act="ranged"   disabled><span class="icon">🏹</span><span class="name">Ranged</span><span class="cd">d20+DEX</span></button>
      <button class="quick-btn" data-act="spell"    disabled><span class="icon">🔮</span><span class="name">Spell</span><span class="cd">d20+INT</span></button>
      <button class="quick-btn" data-act="defend"   disabled><span class="icon">🛡️</span><span class="name">Defend</span><span class="cd">+AC</span></button>
      <button class="quick-btn" data-act="dash"     disabled><span class="icon">💨</span><span class="name">Dash</span><span class="cd">reposition</span></button>
      <button class="quick-btn" data-act="potion"   disabled><span class="icon">🧪</span><span class="name">Potion</span><span class="cd">heal</span></button>
      <button class="quick-btn" data-act="rally"    disabled><span class="icon">📯</span><span class="name">Rally</span><span class="cd">+CHA</span></button>
      <button class="quick-btn" data-act="flee"     disabled><span class="icon">🏃</span><span class="name">Flee</span><span class="cd">DEX save</span></button>
    </div>

    <div class="panel" id="narrative" style="margin-top:10px;">
      <div style="text-align:center; padding: 30px; color: var(--ink);">
        <div style="font-size: 2em;">⏳</div>
        <div>Loading the tavern...</div>
      </div>
    </div>
    <div class="controls">
      <button id="micBtn">🎤 Speak</button>
      <button id="rollBtn">🎲 Roll d20</button>
      <button id="restBtn">💤 Rest</button>
      <button id="resetBtn">🔄 New Quest</button>
    </div>
    <input id="textInput" type="text" placeholder="Or type your action and press Enter..." />
    <div id="status">Loading...</div>
  </div>

  <div class="sidebar">
    <div class="panel stat-block">
      <h3>🛡️ Hero Sheet</h3>
      <div id="charName" style="text-align:center;font-weight:bold;font-size:1.1em;color:var(--magic);">—</div>
      <div class="hp-bar" id="hpBar">
        <div class="hp-fill" id="hpFill" style="width:100%"></div>
        <div class="hp-text" id="hpText">— / —</div>
      </div>
      <div class="stat-row"><span>⚔️ STR</span><span class="value" id="stat-str">—</span></div>
      <div class="stat-row"><span>🏹 DEX</span><span class="value" id="stat-dex">—</span></div>
      <div class="stat-row"><span>🧠 INT</span><span class="value" id="stat-int">—</span></div>
      <div class="stat-row"><span>✨ CHA</span><span class="value" id="stat-cha">—</span></div>
      <div class="stat-row"><span>⭐ XP</span><span class="value" id="stat-xp">0</span></div>
      <div class="stat-row"><span>💰 Gold</span><span class="value" id="stat-gold">0</span></div>
    </div>
    <div class="panel stat-block">
      <h3>👹 Enemy</h3>
      <div id="enemyName" style="text-align:center;font-weight:bold;color:var(--blood);">—</div>
      <div class="hp-bar"><div class="hp-fill" id="enemyHpFill" style="width:0%;background:linear-gradient(90deg,#8b1a1a,#d9534f);"></div><div class="hp-text" id="enemyHpText">—</div></div>
      <div class="stat-row"><span>AC</span><span class="value" id="enemyAc">—</span></div>
      <div class="stat-row"><span>ATK</span><span class="value" id="enemyAtk">—</span></div>
    </div>
    <div class="panel stat-block">
      <h3>🎒 Inventory</h3>
      <div id="inventory"></div>
    </div>
    <div class="panel stat-block">
      <h3>📜 Quest Log</h3>
      <div id="questLog" style="font-size:0.8em;"></div>
      <div class="mute-row">
        <input type="checkbox" id="muteVoice" />
        <label for="muteVoice">🔇 Mute DM voice</label>
      </div>
    </div>
  </div>
</div>

<script>
'use strict';

/* ============================================================
   VOICE QUEST 3D · Boot order: UI first, then 3D
   ============================================================ */

// ---------- DATA ----------
const characters = {
  fighter:  { name: 'Sir Aldric',  icon: '⚔️', hp: 30, maxHp: 30, str: 16, dex: 12, int: 10, cha: 12, color: 0xc9a227, inv: ['Longsword', 'Shield', 'Healing Potion'] },
  rogue:    { name: 'Vex',         icon: '🗡️', hp: 22, maxHp: 22, str: 11, dex: 17, int: 13, cha: 14, color: 0x6a1f6a, inv: ['Daggers', 'Lockpicks', 'Smoke Bomb'] },
  wizard:   { name: 'Lyra',        icon: '🔮', hp: 18, maxHp: 18, str: 8,  dex: 12, int: 18, cha: 13, color: 0x5b3a8e, inv: ['Spellbook', 'Wand', 'Mana Crystal'] },
  cleric:   { name: 'Tomas',       icon: '⛪', hp: 26, maxHp: 26, str: 13, dex: 10, int: 12, cha: 16, color: 0xe8d4a0, inv: ['Mace', 'Holy Symbol', 'Healing Word'] },
  ranger:   { name: 'Kira',        icon: '🏹', hp: 24, maxHp: 24, str: 13, dex: 16, int: 12, cha: 11, color: 0x3a6b3a, inv: ['Longbow', 'Hunting Knife', 'Wolf Companion'] },
  bard:     { name: 'Finn',        icon: '🎵', hp: 20, maxHp: 20, str: 10, dex: 14, int: 13, cha: 17, color: 0xff8a1a, inv: ['Lute', 'Rapier', 'Vial of Mead'] }
};

const scenes = [
  { id: 'entrance', text: "You stand before the moss-shrouded entrance of the Dungeon of Echoes. A cold wind whispers your name. Two stone statues flank a rusted iron gate. Beside it, a small chest, half-buried in vines.",
    options: ['examine chest', 'open gate', 'inspect statues', 'listen to wind'] },
  { id: 'corridor', text: "Beyond the gate, a long corridor stretches into shadow. Torches flicker on their own. Three passages branch ahead: left descends, right glows blue, the center is pitch black.",
    options: ['go left', 'go right', 'go forward', 'sneak quietly'] },
  { id: 'goblin', text: "A goblin scout leaps from the shadows, rusty scimitar drawn! It hisses, eyes darting toward a small pouch at its belt.",
    options: ['fight (use buttons!)', 'intimidate', 'persuade'],
    enemy: { name: 'Goblin Scout', hp: 12, maxHp: 12, atk: 4, ac: 12, model: 'goblin', color: 0x6b8a3a } },
  { id: 'puzzle', text: "A vast chamber. A stone pedestal bears three glowing runes: a flame 🔥, a wave 🌊, and a leaf 🍃. Inscription: 'Only the cycle endures — what consumes, what extinguishes, what is born again?'",
    options: ['press flame', 'press wave', 'press leaf', 'all three in order'] },
  { id: 'dragon', text: "The final chamber yawns before you. Crimson scales shift in the gloom. Pyraxis the young red dragon raises her horned head: 'Mortal... will you fight, flee, or perhaps... bargain?'",
    options: ['fight (use buttons!)', 'flee', 'negotiate', 'offer tribute'],
    enemy: { name: 'Pyraxis', hp: 60, maxHp: 60, atk: 8, ac: 16, model: 'dragon', color: 0xc41a1a } }
];

let state = {
  scene: null, player: null, xp: 0, gold: 0,
  currentEnemy: null, questLog: [], inCombat: false,
  combatLock: false, defending: false, dashed: false
};

// ---------- DOM refs ----------
const narrative = document.getElementById('narrative');
const statusEl = document.getElementById('status');
const micBtn = document.getElementById('micBtn');
const rollBtn = document.getElementById('rollBtn');
const restBtn = document.getElementById('restBtn');
const resetBtn = document.getElementById('resetBtn');
const textInput = document.getElementById('textInput');
const muteVoice = document.getElementById('muteVoice');
const arenaState = document.getElementById('arenaState');
const floatingDamage = document.getElementById('floatingDamage');

// ---------- DICE ----------
function rollDie(s) { return Math.floor(Math.random() * s) + 1; }
function rollD20() { return rollDie(20); }
function mod(score) { return Math.floor((score - 10) / 2); }

// ---------- NARRATION ----------
function speak(text) {
  if (muteVoice.checked || !window.speechSynthesis) return;
  try {
    window.speechSynthesis.cancel();
    const clean = text.replace(/<[^>]*>/g, '').replace(/[\u{1F300}-\u{1FAFF}\u{2600}-\u{27BF}]/gu, '');
    const utter = new SpeechSynthesisUtterance(clean);
    utter.rate = 0.95;
    utter.pitch = 0.85;
    const voices = window.speechSynthesis.getVoices();
    const preferred = voices.find(v => /male|daniel|fred|alex/i.test(v.name)) || voices.find(v => v.lang && v.lang.startsWith('en'));
    if (preferred) utter.voice = preferred;
    window.speechSynthesis.speak(utter);
  } catch (e) {}
}

function addTurn(dmText, playerText) {
  const turn = document.createElement('div');
  turn.className = 'turn';
  let html = '<div class="dm">' + dmText + '</div>';
  if (playerText) html = '<div class="you">▶ "' + playerText + '"</div>' + html;
  turn.innerHTML = html;
  narrative.appendChild(turn);
  narrative.scrollTop = narrative.scrollHeight;
  speak(dmText);
}

function addLog(entry) {
  state.questLog.push(entry);
  document.getElementById('questLog').innerHTML = state.questLog.slice(-6).map(e => '📜 ' + e).join('<br>');
}

// ---------- UI updates ----------
function updateSheet() {
  if (!state.player) return;
  const p = state.player;
  document.getElementById('charName').textContent = p.icon + ' ' + p.name;
  document.getElementById('hpFill').style.width = (p.hp / p.maxHp * 100) + '%';
  document.getElementById('hpText').textContent = p.hp + ' / ' + p.maxHp + ' HP';
  document.getElementById('hpBar').classList.toggle('low', p.hp / p.maxHp < 0.4);
  ['str','dex','int','cha'].forEach(s => {
    document.getElementById('stat-'+s).textContent = p[s] + ' (' + (mod(p[s]) >= 0 ? '+' : '') + mod(p[s]) + ')';
  });
  document.getElementById('stat-xp').textContent = state.xp;
  document.getElementById('stat-gold').textContent = state.gold;
  document.getElementById('inventory').innerHTML = p.inv.map(i => '<span class="inventory-item">' + i + '</span>').join('');
}

function updateEnemyUI() {
  const e = state.currentEnemy;
  if (!e) {
    document.getElementById('enemyName').textContent = '—';
    document.getElementById('enemyHpFill').style.width = '0%';
    document.getElementById('enemyHpText').textContent = '—';
    document.getElementById('enemyAc').textContent = '—';
    document.getElementById('enemyAtk').textContent = '—';
    return;
  }
  document.getElementById('enemyName').textContent = '💀 ' + e.name;
  document.getElementById('enemyHpFill').style.width = Math.max(0, (e.hp / e.maxHp) * 100) + '%';
  document.getElementById('enemyHpText').textContent = Math.max(0, e.hp) + ' / ' + e.maxHp + ' HP';
  document.getElementById('enemyAc').textContent = e.ac;
  document.getElementById('enemyAtk').textContent = 'd' + e.atk + '+1';
}

function setQuickActions(enabled) {
  document.querySelectorAll('.quick-btn').forEach(b => b.disabled = !enabled);
}

function popDamage(text, x, y, kind) {
  const d = document.createElement('div');
  d.className = 'dmg-popup ' + (kind === 'heal' ? 'heal' : kind === 'crit' ? 'crit' : '');
  d.textContent = text;
  d.style.left = x + 'px';
  d.style.top  = y + 'px';
  floatingDamage.appendChild(d);
  setTimeout(() => d.remove(), 1200);
}

/* ============================================================
   3D ARENA - lazy init, fully isolated
   ============================================================ */
const arenaCanvas = document.getElementById('arena3d');
let renderer = null, scene3d = null, camera = null;
let hero3d = null, enemy3d = null;
let heroAnchor, enemyAnchor, heroTarget, enemyTarget;
let cameraOrbit = { theta: 0, phi: 0.45, dist: 9 };
let dragging = false, lastX = 0, lastY = 0;
let projectiles = [];
let particles = [];
let arenaReady = false;

function vec3(x, y, z) {
  if (typeof THREE !== 'undefined') return new THREE.Vector3(x, y, z);
  return { x: x, y: y, z: z, clone: function(){return vec3(this.x,this.y,this.z);}, copy: function(){}, lerp: function(){}, add: function(){return this;}, distanceTo: function(){return 0;} };
}

function updateCamera() {
  if (!camera) return;
  const x = Math.cos(cameraOrbit.theta) * Math.cos(cameraOrbit.phi) * cameraOrbit.dist;
  const y = Math.sin(cameraOrbit.phi) * cameraOrbit.dist;
  const z = Math.sin(cameraOrbit.theta) * Math.cos(cameraOrbit.phi) * cameraOrbit.dist;
  camera.position.set(x, y + 1, z);
  camera.lookAt(0, 0.5, 0);
}

function getArenaSize() {
  const wrap = document.getElementById('arenaWrap');
  return {
    w: wrap.clientWidth || 800,
    h: wrap.clientHeight || 380
  };
}

function resizeArena() {
  if (!renderer || !camera) return;
  const s = getArenaSize();
  renderer.setSize(s.w, s.h, false);
  camera.aspect = s.w / s.h;
  camera.updateProjectionMatrix();
}

function initArena() {
  if (typeof THREE === 'undefined') {
    console.warn('[VQ3D] THREE not available — running 2D mode');
    arenaState.textContent = '— 2D MODE —';
    return false;
  }
  try {
    heroAnchor = new THREE.Vector3(-3, 0, 0);
    enemyAnchor = new THREE.Vector3(3, 0, 0);
    heroTarget = heroAnchor.clone();
    enemyTarget = enemyAnchor.clone();

    const s = getArenaSize();
    renderer = new THREE.WebGLRenderer({ canvas: arenaCanvas, antialias: true, alpha: false });
    renderer.setPixelRatio(window.devicePixelRatio || 1);
    renderer.setSize(s.w, s.h, false);
    renderer.setClearColor(0x100808, 1);

    scene3d = new THREE.Scene();
    scene3d.fog = new THREE.Fog(0x1a0a0a, 8, 22);

    camera = new THREE.PerspectiveCamera(50, s.w / s.h, 0.1, 100);
    updateCamera();

    scene3d.add(new THREE.AmbientLight(0xffaa55, 0.5));
    const torch1 = new THREE.PointLight(0xff8833, 1.8, 18);
    torch1.position.set(-5, 4, 5);
    scene3d.add(torch1);
    const torch2 = new THREE.PointLight(0x8855ff, 1.0, 18);
    torch2.position.set(5, 4, -5);
    scene3d.add(torch2);
    const sun = new THREE.DirectionalLight(0xffffff, 0.6);
    sun.position.set(2, 10, 5);
    scene3d.add(sun);

    // Floor tiles
    const tileGeo = new THREE.BoxGeometry(0.95, 0.1, 0.95);
    for (let x = -4; x <= 4; x++) {
      for (let z = -3; z <= 3; z++) {
        const isDark = (x + z) % 2 === 0;
        const mat = new THREE.MeshLambertMaterial({ color: isDark ? 0x2a1810 : 0x4a2818 });
        const tile = new THREE.Mesh(tileGeo, mat);
        tile.position.set(x, -0.05, z);
        scene3d.add(tile);
      }
    }
    // Pillars
    const pillarGeo = new THREE.CylinderGeometry(0.3, 0.4, 4, 8);
    const pillarMat = new THREE.MeshLambertMaterial({ color: 0x3a2820 });
    [[-5,-4],[-5,4],[5,-4],[5,4]].forEach(p => {
      const m = new THREE.Mesh(pillarGeo, pillarMat);
      m.position.set(p[0], 1.5, p[1]);
      scene3d.add(m);
    });

    arenaCanvas.addEventListener('mousedown', e => { dragging = true; lastX = e.clientX; lastY = e.clientY; });
    window.addEventListener('mouseup', () => dragging = false);
    window.addEventListener('mousemove', e => {
      if (!dragging) return;
      cameraOrbit.theta -= (e.clientX - lastX) * 0.01;
      cameraOrbit.phi = Math.max(0.1, Math.min(Math.PI/2 - 0.05, cameraOrbit.phi - (e.clientY - lastY) * 0.005));
      lastX = e.clientX; lastY = e.clientY;
      updateCamera();
    });
    arenaCanvas.addEventListener('wheel', e => {
      e.preventDefault();
      cameraOrbit.dist = Math.max(5, Math.min(18, cameraOrbit.dist + e.deltaY * 0.01));
      updateCamera();
    }, { passive: false });

    window.addEventListener('resize', resizeArena);

    arenaReady = true;
    animate();
    console.log('[VQ3D] Arena ready', s.w, 'x', s.h);
    return true;
  } catch (e) {
    console.error('[VQ3D] initArena failed:', e);
    return false;
  }
}

function buildHero(color) {
  const g = new THREE.Group();
  const body = new THREE.Mesh(
    new THREE.CylinderGeometry(0.3, 0.4, 0.9, 8),
    new THREE.MeshLambertMaterial({ color: color })
  );
  body.position.y = 0.55;
  g.add(body);
  const head = new THREE.Mesh(
    new THREE.SphereGeometry(0.25, 12, 10),
    new THREE.MeshLambertMaterial({ color: 0xf4d4a0 })
  );
  head.position.y = 1.25;
  g.add(head);
  const weapon = new THREE.Mesh(
    new THREE.BoxGeometry(0.08, 0.7, 0.08),
    new THREE.MeshLambertMaterial({ color: 0xc9c9c9 })
  );
  weapon.position.set(0.4, 0.7, 0);
  g.add(weapon);
  const shield = new THREE.Mesh(
    new THREE.BoxGeometry(0.05, 0.45, 0.4),
    new THREE.MeshLambertMaterial({ color: 0xc9a227 })
  );
  shield.position.set(-0.4, 0.6, 0);
  g.add(shield);
  g.userData = { body: body, weapon: weapon, shield: shield };
  return g;
}

function buildEnemy(type, color) {
  const g = new THREE.Group();
  if (type === 'dragon') {
    const bodyMat = new THREE.MeshLambertMaterial({ color: color });
    const body = new THREE.Mesh(new THREE.SphereGeometry(0.9, 16, 12), bodyMat);
    body.position.y = 1.0;
    body.scale.set(1.4, 0.9, 0.9);
    g.add(body);
    const head = new THREE.Mesh(new THREE.ConeGeometry(0.45, 0.9, 8), bodyMat);
    head.position.set(-1.2, 1.4, 0);
    head.rotation.z = Math.PI / 2;
    g.add(head);
    const wingMat = new THREE.MeshLambertMaterial({ color: 0x6a0a0a, side: THREE.DoubleSide });
    const wingL = new THREE.Mesh(new THREE.PlaneGeometry(1.5, 1.0), wingMat);
    wingL.position.set(0.2, 1.6, 0.7);
    wingL.rotation.set(0.3, 0, -0.5);
    g.add(wingL);
    const wingR = new THREE.Mesh(new THREE.PlaneGeometry(1.5, 1.0), wingMat);
    wingR.position.set(0.2, 1.6, -0.7);
    wingR.rotation.set(-0.3, 0, -0.5);
    g.add(wingR);
    g.userData = { body: body, wings: [wingL, wingR], head: head };
  } else {
    const bodyMat = new THREE.MeshLambertMaterial({ color: color });
    const body = new THREE.Mesh(new THREE.SphereGeometry(0.35, 12, 10), bodyMat);
    body.position.y = 0.45;
    body.scale.set(1, 0.9, 1);
    g.add(body);
    const head = new THREE.Mesh(new THREE.SphereGeometry(0.28, 12, 10), bodyMat);
    head.position.y = 0.95;
    g.add(head);
    const earGeo = new THREE.ConeGeometry(0.08, 0.3, 6);
    const earL = new THREE.Mesh(earGeo, bodyMat);
    earL.position.set(0.25, 1.05, 0);
    earL.rotation.z = -Math.PI/3;
    g.add(earL);
    const earR = new THREE.Mesh(earGeo, bodyMat);
    earR.position.set(-0.25, 1.05, 0);
    earR.rotation.z = Math.PI/3;
    g.add(earR);
    const weapon = new THREE.Mesh(
      new THREE.BoxGeometry(0.06, 0.5, 0.06),
      new THREE.MeshLambertMaterial({ color: 0x8a6a3a })
    );
    weapon.position.set(0.35, 0.6, 0);
    g.add(weapon);
    g.userData = { body: body, weapon: weapon };
  }
  return g;
}

function setupCombatants() {
  if (!arenaReady) return;
  if (hero3d) { scene3d.remove(hero3d); hero3d = null; }
  if (enemy3d) { scene3d.remove(enemy3d); enemy3d = null; }
  if (!state.player) return;
  hero3d = buildHero(state.player.color);
  hero3d.position.copy(heroAnchor);
  hero3d.lookAt(enemyAnchor);
  scene3d.add(hero3d);
  if (state.currentEnemy) {
    enemy3d = buildEnemy(state.currentEnemy.model || 'goblin', state.currentEnemy.color || 0x6b8a3a);
    enemy3d.position.copy(enemyAnchor);
    enemy3d.lookAt(heroAnchor);
    scene3d.add(enemy3d);
  }
  heroTarget = heroAnchor.clone();
  enemyTarget = enemyAnchor.clone();
}

let bobT = 0;
function animate() {
  if (!arenaReady) return;
  requestAnimationFrame(animate);
  bobT += 0.05;
  if (hero3d) {
    hero3d.position.lerp(heroTarget, 0.15);
    if (hero3d.userData.body) hero3d.userData.body.position.y = 0.55 + Math.sin(bobT) * 0.04;
  }
  if (enemy3d) {
    enemy3d.position.lerp(enemyTarget, 0.12);
    const e = state.currentEnemy;
    if (e && e.model === 'dragon' && enemy3d.userData.wings) {
      const flap = Math.sin(bobT * 1.5) * 0.4;
      enemy3d.userData.wings[0].rotation.x = 0.3 + flap;
      enemy3d.userData.wings[1].rotation.x = -0.3 - flap;
    } else if (enemy3d.userData.body) {
      enemy3d.userData.body.position.y = 0.45 + Math.sin(bobT * 1.4) * 0.05;
    }
  }
  for (let i = projectiles.length - 1; i >= 0; i--) {
    const p = projectiles[i];
    p.mesh.position.lerp(p.target, 0.18);
    p.life -= 1;
    if (p.mesh.position.distanceTo(p.target) < 0.2 || p.life <= 0) {
      scene3d.remove(p.mesh);
      projectiles.splice(i, 1);
      if (p.onHit) p.onHit();
    }
  }
  for (let i = particles.length - 1; i >= 0; i--) {
    const pa = particles[i];
    pa.mesh.position.add(pa.vel);
    pa.vel.y -= 0.005;
    pa.life -= 1;
    pa.mesh.material.opacity = pa.life / pa.maxLife;
    if (pa.life <= 0) {
      scene3d.remove(pa.mesh);
      particles.splice(i, 1);
    }
  }
  renderer.render(scene3d, camera);
}

function spawnProjectile(from, to, color, onHit) {
  if (!arenaReady) { if (onHit) setTimeout(onHit, 300); return; }
  const m = new THREE.Mesh(
    new THREE.SphereGeometry(0.12, 8, 8),
    new THREE.MeshBasicMaterial({ color: color })
  );
  m.position.copy(from);
  scene3d.add(m);
  m.add(new THREE.PointLight(color, 1.2, 4));
  projectiles.push({ mesh: m, target: to.clone(), life: 60, onHit: onHit });
}

function spawnSparks(at, color, count) {
  if (!arenaReady) return;
  count = count || 12;
  for (let i = 0; i < count; i++) {
    const m = new THREE.Mesh(
      new THREE.SphereGeometry(0.06, 6, 6),
      new THREE.MeshBasicMaterial({ color: color, transparent: true, opacity: 1 })
    );
    m.position.copy(at);
    const v = new THREE.Vector3(
      (Math.random() - 0.5) * 0.3,
      Math.random() * 0.25 + 0.05,
      (Math.random() - 0.5) * 0.3
    );
    scene3d.add(m);
    particles.push({ mesh: m, vel: v, life: 30, maxLife: 30 });
  }
}

function heroLunge() {
  if (!arenaReady || !hero3d) return;
  const lunge = enemyTarget.clone().lerp(heroAnchor, 0.4);
  heroTarget = lunge;
  setTimeout(() => { heroTarget = heroAnchor.clone(); }, 350);
}
function enemyLunge() {
  if (!arenaReady || !enemy3d) return;
  const lunge = heroTarget.clone().lerp(enemyAnchor, 0.4);
  enemyTarget = lunge;
  setTimeout(() => { enemyTarget = enemyAnchor.clone(); }, 350);
}
function popOver(target, text, kind) {
  if (!arenaReady || !target) return;
  try {
    const v = target.position.clone();
    v.y += 1.6;
    v.project(camera);
    const w = arenaCanvas.clientWidth;
    const h = arenaCanvas.clientHeight;
    const x = (v.x * 0.5 + 0.5) * w;
    const y = (-v.y * 0.5 + 0.5) * h;
    popDamage(text, x, y, kind);
  } catch (e) {}
}

