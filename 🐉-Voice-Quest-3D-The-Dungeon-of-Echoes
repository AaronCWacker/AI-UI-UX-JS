function selectChar(key) {
  console.log('[VQ3D] selectChar:', key);
  const c = characters[key];
  if (!c) return;
  state.player = {
    name: c.name, icon: c.icon, color: c.color, class: key,
    hp: c.hp, maxHp: c.maxHp,
    str: c.str, dex: c.dex, int: c.int, cha: c.cha,
    inv: c.inv.slice()
  };
  narrative.innerHTML = '';
  addTurn(c.icon + ' You are <b>' + c.name + '</b>, a brave ' + key + '. The villagers cheer as you shoulder your pack and stride toward the haunted hills. After a half-day\'s march, you stand at the dungeon\'s threshold...');
  addLog('Began quest as ' + c.name);
  setupCombatants();
  arenaState.textContent = '— EXPLORATION —';
  updateSheet();
  setTimeout(() => loadScene('entrance'), 1800);
}

function loadScene(id) {
  const scene = scenes.find(s => s.id === id);
  if (!scene) return;
  state.scene = scene;
  state.currentEnemy = scene.enemy ? Object.assign({}, scene.enemy) : null;
  state.inCombat = !!scene.enemy;
  state.defending = false;
  state.dashed = false;

  if (state.inCombat) {
    setupCombatants();
    arenaState.textContent = '⚔️ COMBAT · ' + scene.enemy.name;
    setQuickActions(true);
  } else {
    if (enemy3d && arenaReady) { scene3d.remove(enemy3d); enemy3d = null; }
    arenaState.textContent = '📜 ' + scene.id.toUpperCase();
    setQuickActions(false);
  }
  updateEnemyUI();

  let text = scene.text;
  if (scene.enemy) text += '<br><br>💀 <b>' + scene.enemy.name + '</b> · HP ' + scene.enemy.hp + ' · AC ' + scene.enemy.ac + '<br>⚡ <b>Use the quick-action buttons above to fight!</b>';
  text += '<br><br><i>Options: ' + scene.options.join(' • ') + '</i>';
  addTurn(text);
  statusEl.textContent = state.inCombat ? '⚔️ Combat! Click a quick-action button.' : 'Scene: ' + id + '. Speak or type.';
}

function processAction(input) {
  if (!input || !input.trim()) return;
  const action = input.toLowerCase().trim();
  if (!state.player) {
    for (const key of Object.keys(characters)) {
      if (action.indexOf(key) >= 0 || action.indexOf(characters[key].name.toLowerCase().split(' ')[0]) >= 0) {
        selectChar(key); return;
      }
    }
    addTurn('Choose a hero — say fighter, rogue, wizard, cleric, ranger, or bard.', input);
    return;
  }
  if (state.currentEnemy) handleCombatVoice(action, input);
  else handleExploration(action, input);
}

function handleExploration(action, raw) {
  const scene = state.scene;
  if (!scene) return;
  if (scene.id === 'entrance') {
    if (/chest|loot|treasure/.test(action)) {
      const r = rollD20() + mod(state.player.dex);
      if (r >= 12) {
        state.gold += 25;
        state.player.inv.push('Silver Key');
        addTurn('<span class="roll">DEX ' + r + '</span> ✨ <span class="crit">SUCCESS!</span> Inside: <b>25 gold</b> and a runic silver key.', raw);
      } else {
        state.player.hp -= 4;
        addTurn('<span class="roll">DEX ' + r + '</span> 💀 <span class="fail">TRAP!</span> <b>4 damage</b>.', raw);
      }
      updateSheet();
      setTimeout(() => loadScene('corridor'), 2200);
    } else if (/gate|open|enter/.test(action)) {
      addTurn('You push the iron gate. It groans open.', raw);
      setTimeout(() => loadScene('corridor'), 1500);
    } else if (/statue|inspect/.test(action)) {
      const r = rollD20() + mod(state.player.int);
      if (r >= 13) {
        state.xp += 10;
        addTurn('<span class="roll">INT ' + r + '</span> ✨ Inscription: \'Fire fades, water dries, but life returns.\' (<b>+10 XP</b>)', raw);
      } else {
        addTurn('<span class="roll">INT ' + r + '</span> The statues are old.', raw);
      }
      updateSheet();
    } else if (/listen|wind|whisper/.test(action)) {
      addTurn('The wind speaks: <i>\'Echoes... echoes...\'</i>', raw);
    } else {
      addTurn('<i>You may examine chest, open gate, inspect statues, or listen.</i>', raw);
    }
    return;
  }
  if (scene.id === 'corridor') {
    if (/left|down|descend/.test(action)) {
      addTurn('You descend left. Suddenly — movement!', raw);
      setTimeout(() => loadScene('goblin'), 1400);
    } else if (/right|blue|glow/.test(action)) {
      addTurn('The blue glow leads to a circular chamber...', raw);
      setTimeout(() => loadScene('puzzle'), 1400);
    } else if (/forward|center|black|pitch/.test(action)) {
      const r = rollD20() + mod(state.player.dex);
      if (r >= 10) {
        addTurn('<span class="roll">DEX ' + r + '</span> ✨ A great chamber awaits...', raw);
        setTimeout(() => loadScene('dragon'), 1800);
      } else {
        state.player.hp -= 6;
        addTurn('<span class="roll">DEX ' + r + '</span> 💀 Pit trap! <b>6 damage</b>.', raw);
        updateSheet();
      }
    } else if (/sneak|quiet|stealth/.test(action)) {
      const r = rollD20() + mod(state.player.dex);
      if (r >= 12) {
        state.xp += 5;
        addTurn('<span class="roll">Stealth ' + r + '</span> ✨ You slip past. <b>+5 XP</b>.', raw);
        setTimeout(() => loadScene('puzzle'), 1600);
      } else {
        addTurn('<span class="roll">Stealth ' + r + '</span> 💀 Goblin turns!', raw);
        setTimeout(() => loadScene('goblin'), 1400);
      }
      updateSheet();
    } else {
      addTurn('<i>Three passages: left, right (blue), forward (dark). Or sneak.</i>', raw);
    }
    return;
  }
  if (scene.id === 'puzzle') {
    if (/leaf|life|all.*three|cycle|order/.test(action)) {
      state.xp += 25;
      state.gold += 50;
      state.player.inv.push('Star of Aethel');
      addTurn('✨ <span class="crit">SOLVED!</span> <b>Star of Aethel</b> claimed! <b>+25 XP, +50 gold</b>.', raw);
      updateSheet();
      setTimeout(() => loadScene('dragon'), 2800);
    } else if (/flame|fire/.test(action)) {
      state.player.hp -= 5;
      addTurn('💀 Flame jet! <b>5 damage</b>.', raw);
      updateSheet();
    } else if (/wave|water/.test(action)) {
      addTurn('Water gushes briefly. Nothing.', raw);
    } else {
      addTurn('<i>\'What consumes, what extinguishes, what is born again?\'</i>', raw);
    }
    return;
  }
}

function handleCombatVoice(action, raw) {
  const scene = state.scene;
  if (scene.id === 'goblin') {
    if (/intimidate|scare|threaten/.test(action)) {
      const r = rollD20() + mod(state.player.cha);
      if (r >= 12) {
        state.gold += 8;
        addTurn('<span class="roll">CHA ' + r + '</span> ✨ Goblin flees! <b>+8 gold</b>.', raw);
        state.currentEnemy = null; state.xp += 20; updateSheet(); updateEnemyUI();
        setQuickActions(false);
        setTimeout(() => loadScene('puzzle'), 1800);
        return;
      }
    }
    if (/persuade|talk|reason/.test(action)) {
      const r = rollD20() + mod(state.player.cha);
      if (r >= 13) {
        addTurn('<span class="roll">CHA ' + r + '</span> ✨ Goblin yields a Trinket.', raw);
        state.player.inv.push('Goblin Trinket');
        state.currentEnemy = null; state.xp += 15; updateSheet(); updateEnemyUI();
        setQuickActions(false);
        setTimeout(() => loadScene('puzzle'), 1800);
        return;
      }
    }
  }
  if (scene.id === 'dragon') {
    if (/negotiate|bargain|talk|parley/.test(action)) {
      const r = rollD20() + mod(state.player.cha);
      if (r >= 15) {
        state.xp += 100;
        addTurn('<span class="roll">CHA ' + r + '</span> ✨ <span class="crit">PEACE!</span> <b>+100 XP</b>', raw);
        endQuest('peace');
        return;
      }
    }
    if (/tribute|offer|gift/.test(action)) {
      if (state.gold >= 25) {
        state.gold -= 25;
        addTurn('💰 25 gold paid. <b>QUEST COMPLETE.</b>', raw);
        endQuest('tribute');
      } else {
        addTurn('Empty-handed.', raw);
      }
      return;
    }
    if (/flee|run|escape/.test(action)) { actionFlee(); return; }
  }
  addTurn('⚡ <i>Use the quick-action buttons above for combat!</i>', raw);
}

// ---------- QUICK ACTIONS ----------
function actionStrike() {
  const player = state.player;
  const enemy = state.currentEnemy;
  if (!enemy || state.combatLock) return;
  state.combatLock = true;
  setQuickActions(false);
  heroLunge();
  setTimeout(() => {
    const atk = rollD20() + mod(player.str);
    const isCrit = atk - mod(player.str) === 20;
    if (atk >= enemy.ac) {
      let dmg = rollDie(8) + mod(player.str);
      if (isCrit) dmg += rollDie(8);
      dmg = Math.max(1, dmg);
      enemy.hp -= dmg;
      if (enemy3d) {
        spawnSparks(enemy3d.position.clone().add(new THREE.Vector3(0, 0.8, 0)), 0xffaa33, 14);
        popOver(enemy3d, '-' + dmg, isCrit ? 'crit' : 'damage');
      }
      addTurn('⚔️ <span class="roll">' + atk + '</span> vs AC ' + enemy.ac + ' → ' + (isCrit ? '<span class="crit">CRIT!</span> ' : '<span class="crit">HIT!</span> ') + '<b>' + dmg + ' damage</b>');
      checkEnemyDeath();
    } else {
      addTurn('⚔️ <span class="roll">' + atk + '</span> vs AC ' + enemy.ac + ' → <span class="fail">MISS</span>');
    }
    updateEnemyUI();
    if (state.currentEnemy) setTimeout(enemyAutoTurn, 800);
    else { state.combatLock = false; }
  }, 350);
}

function actionRanged() {
  const player = state.player;
  const enemy = state.currentEnemy;
  if (!enemy || state.combatLock) return;
  state.combatLock = true;
  setQuickActions(false);
  if (hero3d && enemy3d) {
    const from = hero3d.position.clone().add(new THREE.Vector3(0, 1.0, 0));
    const to = enemy3d.position.clone().add(new THREE.Vector3(0, 0.9, 0));
    spawnProjectile(from, to, 0xffcc66, () => doRangedHit(player, enemy));
  } else doRangedHit(player, enemy);
}
function doRangedHit(player, enemy) {
  const atk = rollD20() + mod(player.dex);
  if (atk >= enemy.ac) {
    const dmg = Math.max(1, rollDie(6) + mod(player.dex));
    enemy.hp -= dmg;
    if (enemy3d) {
      spawnSparks(enemy3d.position.clone().add(new THREE.Vector3(0, 0.9, 0)), 0xffcc66, 10);
      popOver(enemy3d, '-' + dmg, 'damage');
    }
    addTurn('🏹 <span class="roll">' + atk + '</span> → <span class="crit">HIT!</span> <b>' + dmg + ' damage</b>');
    checkEnemyDeath();
  } else {
    addTurn('🏹 <span class="roll">' + atk + '</span> → <span class="fail">miss</span>');
  }
  updateEnemyUI();
  if (state.currentEnemy) setTimeout(enemyAutoTurn, 600);
  else { state.combatLock = false; }
}

function actionSpell() {
  const player = state.player;
  const enemy = state.currentEnemy;
  if (!enemy || state.combatLock) return;
  state.combatLock = true;
  setQuickActions(false);
  if (hero3d && enemy3d) {
    const from = hero3d.position.clone().add(new THREE.Vector3(0, 1.2, 0));
    const to = enemy3d.position.clone().add(new THREE.Vector3(0, 0.9, 0));
    spawnProjectile(from, to, 0x9966ff, () => doSpellHit(player, enemy));
  } else doSpellHit(player, enemy);
}
function doSpellHit(player, enemy) {
  const atk = rollD20() + mod(player.int);
  if (atk >= enemy.ac) {
    const dmg = Math.max(1, rollDie(10) + mod(player.int));
    enemy.hp -= dmg;
    if (enemy3d) {
      spawnSparks(enemy3d.position.clone().add(new THREE.Vector3(0, 0.9, 0)), 0xaa66ff, 18);
      popOver(enemy3d, '-' + dmg, 'crit');
    }
    addTurn('🔮 <span class="roll">' + atk + '</span> ✨ Magic strikes! <b>' + dmg + ' damage</b>');
    checkEnemyDeath();
  } else {
    addTurn('🔮 <span class="roll">' + atk + '</span> 💀 Spell fizzles');
  }
  updateEnemyUI();
  if (state.currentEnemy) setTimeout(enemyAutoTurn, 600);
  else { state.combatLock = false; }
}

function actionDefend() {
  if (!state.currentEnemy || state.combatLock) return;
  state.combatLock = true;
  setQuickActions(false);
  state.defending = true;
  if (hero3d) {
    spawnSparks(hero3d.position.clone().add(new THREE.Vector3(0, 0.8, 0)), 0xc9a227, 12);
    popOver(hero3d, '+AC', 'heal');
  }
  addTurn('🛡️ Guard up! (+4 AC, half damage next hit)');
  setTimeout(enemyAutoTurn, 600);
}

function actionDash() {
  if (!state.currentEnemy || state.combatLock) return;
  state.combatLock = true;
  setQuickActions(false);
  state.dashed = true;
  if (typeof THREE !== 'undefined') {
    heroAnchor = new THREE.Vector3(2, 0, -2.5);
    heroTarget = heroAnchor.clone();
  }
  if (hero3d) spawnSparks(hero3d.position.clone().add(new THREE.Vector3(0, 0.5, 0)), 0x66ddff, 8);
  addTurn('💨 Flanking position! Advantage on next attack.');
  setTimeout(() => {
    state.combatLock = false;
    setQuickActions(true);
  }, 600);
}

function actionPotion() {
  const player = state.player;
  if (!player) return;
  const idx = player.inv.findIndex(i => /potion|heal|mead/i.test(i));
  if (idx < 0) {
    addTurn('🧪 No potions left!');
    return;
  }
  if (state.combatLock) return;
  state.combatLock = true;
  setQuickActions(false);
  const heal = rollDie(8) + 4;
  const before = player.hp;
  player.hp = Math.min(player.maxHp, player.hp + heal);
  player.inv.splice(idx, 1);
  if (hero3d) {
    spawnSparks(hero3d.position.clone().add(new THREE.Vector3(0, 1.2, 0)), 0x55ff55, 14);
    popOver(hero3d, '+' + (player.hp - before), 'heal');
  }
  addTurn('🧪 Quaff! +<b>' + (player.hp - before) + ' HP</b>.');
  updateSheet();
  if (state.currentEnemy) setTimeout(enemyAutoTurn, 700);
  else { state.combatLock = false; }
}

function actionRally() {
  if (!state.currentEnemy || state.combatLock) return;
  state.combatLock = true;
  setQuickActions(false);
  const player = state.player;
  const r = rollD20() + mod(player.cha);
  if (r >= 12) {
    const heal = rollDie(6);
    player.hp = Math.min(player.maxHp, player.hp + heal);
    if (hero3d) {
      spawnSparks(hero3d.position.clone().add(new THREE.Vector3(0, 1.5, 0)), 0xffd700, 16);
      popOver(hero3d, '+' + heal + ' ⭐', 'heal');
    }
    addTurn('📯 <span class="roll">CHA ' + r + '</span> ✨ Rally! +<b>' + heal + ' HP</b>');
    updateSheet();
  } else {
    addTurn('📯 <span class="roll">CHA ' + r + '</span> Voice falters.');
  }
  if (state.currentEnemy) setTimeout(enemyAutoTurn, 700);
  else { state.combatLock = false; }
}

function actionFlee() {
  if (!state.currentEnemy || state.combatLock) return;
  state.combatLock = true;
  setQuickActions(false);
  const player = state.player;
  const r = rollD20() + mod(player.dex);
  if (r >= 14) {
    addTurn('🏃 <span class="roll">DEX ' + r + '</span> ✨ Escape!');
    if (state.scene.id === 'dragon') { endQuest('flee'); return; }
    state.currentEnemy = null;
    setQuickActions(false);
    updateEnemyUI();
    setTimeout(() => loadScene('corridor'), 1500);
  } else {
    addTurn('🏃 <span class="roll">DEX ' + r + '</span> 💀 Cornered!');
    setTimeout(enemyAutoTurn, 700);
  }
}

function enemyAutoTurn() {
  const player = state.player;
  const enemy = state.currentEnemy;
  if (!enemy) { state.combatLock = false; setQuickActions(false); return; }
  enemyLunge();
  setTimeout(() => {
    const atk = rollD20() + 3;
    const ac = 12 + (state.defending ? 4 : 0) + mod(player.dex);
    if (atk >= ac) {
      let dmg = rollDie(enemy.atk) + 1;
      if (state.defending) dmg = Math.floor(dmg / 2);
      player.hp -= dmg;
      if (hero3d) {
        spawnSparks(hero3d.position.clone().add(new THREE.Vector3(0, 0.8, 0)), 0xff3333, 12);
        popOver(hero3d, '-' + dmg, 'damage');
      }
      addTurn('💀 <b>' + enemy.name + '</b> hits! <span class="roll">' + atk + '</span> vs AC ' + ac + ' → <span class="fail">' + dmg + ' damage</span>' + (state.defending ? ' (halved!)' : ''));
    } else {
      addTurn('✨ <b>' + enemy.name + '</b> misses! (<span class="roll">' + atk + '</span> vs AC ' + ac + ')');
    }
    updateSheet();
    state.defending = false;
    if (player.hp <= 0) {
      setQuickActions(false);
      endQuest('death');
      return;
    }
    state.combatLock = false;
    setQuickActions(true);
  }, 350);
}

function checkEnemyDeath() {
  const enemy = state.currentEnemy;
  if (!enemy || enemy.hp > 0) return;
  if (enemy3d) {
    enemyTarget = enemy3d.position.clone();
    enemyTarget.y = -0.5;
    if (enemy3d.userData.body) enemy3d.userData.body.material.color.setHex(0x444444);
    spawnSparks(enemy3d.position.clone().add(new THREE.Vector3(0, 0.8, 0)), 0xffd700, 30);
  }
  const reward = state.scene.id === 'dragon' ? 100 : 30;
  const goldReward = state.scene.id === 'dragon' ? 200 : 12;
  state.xp += reward;
  state.gold += goldReward;
  addTurn('🏆 <b>' + enemy.name + ' falls!</b> +' + reward + ' XP, +' + goldReward + ' gold.');
  addLog('Defeated ' + enemy.name);
  state.currentEnemy = null;
  state.combatLock = false;
  setQuickActions(false);
  updateSheet();
  updateEnemyUI();
  arenaState.textContent = '— VICTORY —';
  if (state.scene.id === 'dragon') {
    setTimeout(() => endQuest('victory'), 2500);
  } else {
    setTimeout(() => loadScene('puzzle'), 2500);
  }
}

function endQuest(outcome) {
  let msg = '';
  if (outcome === 'victory') msg = '🏆 <b>VICTORY!</b> Pyraxis defeated!';
  else if (outcome === 'peace') msg = '🕊️ <b>WISE ENDING.</b>';
  else if (outcome === 'tribute') msg = '💰 <b>DIPLOMATIC ENDING.</b>';
  else if (outcome === 'flee') msg = '🏃 <b>SURVIVED.</b>';
  else if (outcome === 'death') msg = '💀 <b>YOU HAVE FALLEN.</b> Click 🔄 to rise anew.';
  addTurn(msg + '<br><br>Final: <b>' + state.xp + ' XP</b> · <b>' + state.gold + ' gold</b>');
  addLog('Quest ended: ' + outcome);
  state.currentEnemy = null;
  state.scene = null;
  arenaState.textContent = '— ' + outcome.toUpperCase() + ' —';
  setQuickActions(false);
}

// ---------- SPEECH RECOGNITION ----------
let recognition = null, listening = false;
function initSpeech() {
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) {
    micBtn.disabled = true;
    micBtn.textContent = '🎤 (n/a)';
    return;
  }
  try {
    recognition = new SR();
    recognition.continuous = false;
    recognition.interimResults = false;
    recognition.lang = 'en-US';
    recognition.onresult = function(e) {
      const t = e.results[0][0].transcript;
      statusEl.textContent = 'Heard: "' + t + '"';
      processAction(t);
    };
    recognition.onerror = function(e) {
      statusEl.textContent = 'Mic: ' + e.error;
      listening = false;
      micBtn.classList.remove('mic-on');
      micBtn.textContent = '🎤 Speak';
    };
    recognition.onend = function() {
      listening = false;
      micBtn.classList.remove('mic-on');
      micBtn.textContent = '🎤 Speak';
    };
  } catch (e) {}
}

micBtn.addEventListener('click', function() {
  if (!recognition) return;
  if (listening) { recognition.stop(); return; }
  try {
    recognition.start();
    listening = true;
    micBtn.classList.add('mic-on');
    micBtn.textContent = '🔴 Listening';
  } catch (err) {
    statusEl.textContent = 'Mic busy.';
  }
});

textInput.addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && textInput.value.trim()) {
    processAction(textInput.value);
    textInput.value = '';
  }
});

rollBtn.addEventListener('click', function() {
  const r = rollD20();
  addTurn('🎲 d20 → <b>' + r + '</b>' + (r === 20 ? ' ✨ NATURAL TWENTY!' : r === 1 ? ' 💀 Fumble!' : ''));
});

restBtn.addEventListener('click', function() {
  if (!state.player) return;
  const heal = rollDie(8) + 2;
  state.player.hp = Math.min(state.player.maxHp, state.player.hp + heal);
  addTurn('💤 Short rest. +<b>' + heal + ' HP</b>.');
  updateSheet();
});

resetBtn.addEventListener('click', function() {
  if (window.speechSynthesis) window.speechSynthesis.cancel();
  state = { scene: null, player: null, xp: 0, gold: 0, currentEnemy: null, questLog: [], inCombat: false, combatLock: false, defending: false, dashed: false };
  document.getElementById('questLog').innerHTML = '';
  document.getElementById('charName').textContent = '—';
  document.getElementById('hpFill').style.width = '100%';
  document.getElementById('hpText').textContent = '— / —';
  ['str','dex','int','cha'].forEach(s => document.getElementById('stat-'+s).textContent = '—');
  document.getElementById('stat-xp').textContent = '0';
  document.getElementById('stat-gold').textContent = '0';
  document.getElementById('inventory').innerHTML = '';
  if (arenaReady) {
    if (hero3d) { scene3d.remove(hero3d); hero3d = null; }
    if (enemy3d) { scene3d.remove(enemy3d); enemy3d = null; }
    heroAnchor = new THREE.Vector3(-3, 0, 0);
    enemyAnchor = new THREE.Vector3(3, 0, 0);
  }
  setQuickActions(false);
  updateEnemyUI();
  showCharSelect();
});

document.querySelectorAll('.quick-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    const act = btn.dataset.act;
    if      (act === 'strike') actionStrike();
    else if (act === 'ranged') actionRanged();
    else if (act === 'spell')  actionSpell();
    else if (act === 'defend') actionDefend();
    else if (act === 'dash')   actionDash();
    else if (act === 'potion') actionPotion();
    else if (act === 'rally')  actionRally();
    else if (act === 'flee')   actionFlee();
  });
});

// ---------- BOOT ----------
// Load Three.js async so it never blocks the game UI.
// The character select works the moment the page loads.
function loadThree(cb) {
  if (typeof THREE !== 'undefined') { cb(true); return; }
  const urls = [
    'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js',
    'https://cdn.jsdelivr.net/npm/three@0.128.0/build/three.min.js',
    'https://unpkg.com/three@0.128.0/build/three.min.js'
  ];
  let i = 0;
  function tryNext() {
    if (i >= urls.length) { cb(false); return; }
    const s = document.createElement('script');
    s.src = urls[i++];
    s.async = true;
    s.onload = () => cb(true);
    s.onerror = tryNext;
    document.head.appendChild(s);
  }
  tryNext();
}

function boot() {
  console.log('[VQ3D] boot');
  // UI FIRST — char select works immediately, no network dependency.
  showCharSelect();
  initSpeech();
  if (window.speechSynthesis) {
    try { window.speechSynthesis.getVoices(); } catch(e) {}
  }
  // Then upgrade to 3D when (and if) Three.js loads.
  loadThree(function(ok) {
    if (!ok) {
      console.warn('[VQ3D] Three.js unavailable — running 2D');
      arenaState.textContent = '— 2D MODE (no internet) —';
      return;
    }
    setTimeout(() => {
      if (initArena()) {
        // If hero already chosen before 3D loaded, set them up now
        if (state.player) setupCombatants();
        setTimeout(resizeArena, 100);
        setTimeout(resizeArena, 500);
      }
    }, 50);
  });
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', boot);
} else {
  boot();
}
</script>

